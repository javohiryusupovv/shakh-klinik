# Telegram Bot — obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram Chat IDs — comma-separated; send a message to the bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_IDS=

# Legacy split config is also supported if TELEGRAM_CHAT_IDS is empty
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_ID_ADMIN=

# Public site URL — used for canonical URLs and OG metadata (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://shakh-clinics.ru

# Google Analytics 4 Measurement ID — obtain from Google Analytics > Admin > Data Streams
NEXT_PUBLIC_GA_ID=

# Yandex Metrika Counter ID — obtain from metrika.yandex.ru > Counters
NEXT_PUBLIC_YM_ID=
