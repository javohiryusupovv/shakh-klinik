          {
            "type": "command",
            "command": "node '/Users/javohir/Desktop/ShaxKlinika/.codex/hooks/gsd-prompt-guard.js'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node '/Users/javohir/Desktop/ShaxKlinika/.codex/hooks/gsd-read-guard.js'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node '/Users/javohir/Desktop/ShaxKlinika/.codex/hooks/gsd-workflow-guard.js'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
